{
  "name": "openrouter",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "generate:db": "cd packages/db && bunx prisma generate && cd ../..",
    "migrate:db": "cd packages/db/prisma && bunx prisma migrate deploy",
    "seed:db": "cd packages/db && bunx prisma db seed && cd ../..",
    "start:primary-backend": "cd apps/primary-backend && bun run dev",
    "start:api-backend": "cd apps/api-backend && bun run dev",
    "start:frontend": "cd apps/frontend && bun run dev"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.10",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "elysia": "1.4.28"
  },
  "resolutions": {
    "elysia": "1.4.28"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.4.9",
    "elysia": "1.4.28"
  }
}